@model IEnumerable<Cadastro.Dominio.Cidade>
@{
    ViewBag.Title = "Index";
    var grid = new WebGrid(Model, defaultSort: "CodigoCidade");
}


@grid.GetHtml(
    "webgrid-table",
    htmlAttributes: new { id = "checkableGrid" },
    fillEmptyRows: true,
    alternatingRowStyle: "alt",
    headerStyle: "grid-header",
    footerStyle: "foot",
    mode: WebGridPagerModes.All,
    emptyRowCellValue: null,
    columns: new[]
    {
        grid.Column("CodigoCidade", "Id"),
        grid.Column("NomeCidade", "Cidade"),
        grid.Column("Uf", "UF"),
        grid.Column("Cep", "Cep")
    }
)
