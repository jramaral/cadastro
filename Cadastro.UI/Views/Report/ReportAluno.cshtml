@model IEnumerable<Cadastro.Dominio.Aluno>
@{
    ViewBag.Title = "Index";
    var grid = new WebGrid(Model, defaultSort: "CodigoID");
}


@grid.GetHtml(
    "webgrid-table",
    htmlAttributes: new { id = "checkableGrid" },
    fillEmptyRows: true,
    alternatingRowStyle: "alt",
    headerStyle: "gridheader",
    footerStyle: "gridfoot",
    mode: WebGridPagerModes.All,
    emptyRowCellValue: null,
    columns: new[]
    {
        grid.Column("Codigo",  "Id"),
        grid.Column("Nome",  "Nome"),
        grid.Column("CPF",  "Cpf"),
        grid.Column("Telefone",  "Telefone"),
        grid.Column("Email",  "Email"),
        grid.Column("Sexo",  "Sexo"),
        grid.Column("Cidade",  "Cidade"),
        grid.Column("Endereco",  "Endereço")
    }
)
